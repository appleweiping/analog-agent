FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV ANALOG_AGENT_NGSPICE_BIN=/usr/bin/ngspice

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        ngspice \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

CMD ["bash"]
